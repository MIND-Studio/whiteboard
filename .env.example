# OIDC issuer for pod sign-in. Defaults to the production pod so a user signed
# into any sibling Mind app gets silent SSO here. Point at the shared Mind CSS
# (http://localhost:3011/ — `docker compose up` at the workspace root, see
# ../SOLID-SERVER.md) to develop fully offline with cross-app SSO.
NEXT_PUBLIC_SOLID_ISSUER=https://pods.mindpods.org/

# Live-collaboration relay (ephemeral y-websocket server, no persistence).
# `npm run relay` starts it on :3112. CSS owns :3111, the app owns :3110.
NEXT_PUBLIC_RELAY_URL=ws://localhost:3112

# Namespace this prototype claims under each user pod. Sibling prototypes claim
# their own (mind-drive, mind-chat, …) so a shared-CSS scenario never collides.
NEXT_PUBLIC_WHITEBOARD_NAMESPACE=mind-whiteboard
