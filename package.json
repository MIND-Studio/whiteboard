    "prepare": "husky"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^4.0.0",
    "@inrupt/solid-client-authn-node": "^3.1.0",
    "@mind-studio/core": "^0.7.0",
    "@mind-studio/ui": "^0.5.0",
    "lucide-react": "^0.460.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
